<?xml version="1.0"?>
<launch>
    <!-- Enable/disable components via args -->
    <arg name="use_camera"   default="true"/>
    <arg name="use_lidar"    default="true"/>
    <arg name="use_keyboard" default="false"/>

    <!-- Camera (CSI / USB) -->
    <include if="$(arg use_camera)" file="$(find jetracer)/launch/cv_video.launch"/>

    <!-- LiDAR (rplidar_ros must be installed separately) -->
    <!-- <include if="$(arg use_lidar)" file="$(find rplidar_ros)/launch/rplidar.launch">
        <arg name="serial_port" value="/dev/ttyACM1"/>ok
    </include> -->

    <!-- Joystick teleoperation -->
    <include file="$(find jetracer)/launch/joy.launch"/>

    <!-- Line following -->
    <include file="$(find jetracer)/launch/line_follow.launch"/>

    <!-- Optional: keyboard teleoperation -->
    <include if="$(arg use_keyboard)" file="$(find jetracer)/launch/keyboard.launch"/>

</launch>
